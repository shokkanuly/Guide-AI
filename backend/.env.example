# ================================================
# GovGuide AI — Environment Variables
# Copy to .env and fill in your values
# ================================================

# --- App ---
APP_NAME="GovGuide AI"
APP_ENV=development          # development | staging | production
APP_VERSION="1.0.0"
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# --- Server ---
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5500

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://govguide:password@localhost:5432/govguide_db
DATABASE_URL_SYNC=postgresql://govguide:password@localhost:5432/govguide_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# --- JWT Auth ---
JWT_SECRET_KEY=your-jwt-secret-key-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.3

# --- ChromaDB (Vector DB) ---
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_PROGRAMS=gov_programs
CHROMA_COLLECTION_LAWS=gov_laws
CHROMA_COLLECTION_DOCS=gov_docs

# --- AWS S3 (File Storage) ---
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=govguide-documents
S3_BUCKET_URL=https://govguide-documents.s3.amazonaws.com

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# --- Email (SMTP) ---
MAIL_USERNAME=noreply@govguide.kz
MAIL_PASSWORD=your-email-password
MAIL_FROM=noreply@govguide.kz
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=true

# --- Rate Limiting ---
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_DEFAULT=100/minute

# --- Feature Flags ---
ENABLE_OCR=false
ENABLE_TELEGRAM_NOTIFICATIONS=true
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_PROACTIVE_MATCHING=true
